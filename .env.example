APP_NAME="PropManage SaaS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database — PostgreSQL + Citus ───────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=citus-coordinator
DB_PORT=5432
DB_DATABASE=propman
DB_USERNAME=postgres
DB_PASSWORD=

# ─── Broadcasting / Cache / Queue / Session ──────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@propertysasa.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Multi-tenancy ───────────────────────────────────────────────────────────
# Central domains (must match config/tenancy.php)
CENTRAL_DOMAINS=localhost,127.0.0.1,propertysasa.com,www.propertysasa.com

# Tenant domain suffix — add wildcard *.propertysasa.test to /etc/hosts for local dev
# e.g. 127.0.0.1 mycompany.propertysasa.test
TENANT_DOMAIN_SUFFIX=.propertysasa.test

# ─── M-Pesa Integration (Safaricom Daraja API) ───────────────────────────────
# Register at https://developer.safaricom.co.ke/
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://yourapp.com/api/mpesa/callback
MPESA_STK_PUSH_URL=https://sandbox.safaricom.co.ke/mpesa/stkpush/v1/processrequest

# ─── Filament / Admin ────────────────────────────────────────────────────────
FILAMENT_FILESYSTEM_DISK=public

# ─── Vite ────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
